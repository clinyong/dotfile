#!/usr/bin/env bash
# pi-web-status — show pi-web web daemon state (background process, not launchctl)

set -euo pipefail

PID_FILE="$HOME/.pi-web/daemon.pid"
SESSIOND_PID_FILE="$HOME/.pi-web/sessiond.pid"
LOG_FILE="$HOME/.pi-web/logs/web-direct.log"
SESSIOND_LOG_FILE="$HOME/.pi-web/logs/sessiond-direct.log"
[[ -f "$SESSIOND_LOG_FILE" ]] || SESSIOND_LOG_FILE="$HOME/.pi-web/logs/sessiond.log"
LAUNCHD_DOMAIN="gui/$(id -u)"
LAUNCHD_LABEL="com.pi-web.web"

# ANSI colors (disabled if not a TTY)
if [[ -t 1 ]]; then
  RED='\033[0;31m'; YEL='\033[0;33m'; GRN='\033[0;32m'; DIM='\033[2m'; NC='\033[0m'
else
  RED=''; YEL=''; GRN=''; DIM=''; NC=''
fi

echo "=== pi-web status ==="

# 1. Background daemon
if [[ -f "$PID_FILE" ]]; then
  pid=$(cat "$PID_FILE" 2>/dev/null || true)
  if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
    uptime=$(ps -o etime= -p "$pid" 2>/dev/null | xargs)
    printf "Background daemon:  ${GRN}RUNNING${NC} (PID %s, uptime %s)\n" "$pid" "$uptime"
  else
    printf "Background daemon:  ${YEL}STALE${NC} (PID file points to %s, not running)\n" "${pid:-?}"
  fi
else
  echo -e "Background daemon:  not tracked (no PID file)"
fi

if [[ -f "$SESSIOND_PID_FILE" ]]; then
  sessiond_pid=$(cat "$SESSIOND_PID_FILE" 2>/dev/null || true)
  if [[ -n "${sessiond_pid:-}" ]] && kill -0 "$sessiond_pid" 2>/dev/null; then
    uptime=$(ps -o etime= -p "$sessiond_pid" 2>/dev/null | xargs)
    printf "Session daemon:      ${GRN}RUNNING${NC} (PID %s, uptime %s)\n" "$sessiond_pid" "$uptime"
  else
    printf "Session daemon:      ${YEL}STALE${NC} (PID file points to %s, not running)\n" "${sessiond_pid:-?}"
  fi
else
  echo -e "Session daemon:      not tracked (no PID file)"
fi

# 2. launchctl web agent (this is the LAN-killer — warn if running)
launchctl_running="no"
if launchctl print "$LAUNCHD_DOMAIN/$LAUNCHD_LABEL" >/dev/null 2>&1; then
  state=$(launchctl print "$LAUNCHD_DOMAIN/$LAUNCHD_LABEL" 2>/dev/null | awk -F'= ' '/state /{print $2; exit}')
  if [[ "$state" == "running" ]]; then
    launchctl_running="yes"
  fi
fi

if [[ "$launchctl_running" == "yes" ]]; then
  printf "LaunchAgent:        ${RED}RUNNING${NC} ${YEL}(will block LAN access!)${NC}\n"
  echo -e "  ${DIM}Fix: pi-web-up will auto-stop it on next start${NC}"
else
  if [[ -f "$HOME/Library/LaunchAgents/${LAUNCHD_LABEL}.plist" ]]; then
    echo -e "LaunchAgent:        ${YEL}plisted but stopped${NC}  (pi-web-up will bootout on start)"
  else
    echo -e "LaunchAgent:        ${GRN}stopped (plist removed)${NC}"
  fi
fi

# 3. Port 8504 — retry briefly because pi-web-server takes ~1s to bind after start
if command -v lsof >/dev/null 2>&1; then
  port_pids=""
  for _ in {1..6}; do
    port_pids=$(lsof -nP -iTCP:8504 -sTCP:LISTEN -t 2>/dev/null || true)
    [[ -n "$port_pids" ]] && break
    sleep 0.5
  done
  if [[ -n "$port_pids" ]]; then
    printf "Port 8504:          ${GRN}listening${NC} (PID %s)\n" "$port_pids"
  else
    printf "Port 8504:          ${YEL}not listening${NC}\n"
  fi
fi

# 4. API health — also retry
api_ok=""
api_ver=""
for _ in {1..6}; do
  if body=$(curl -sS -m 2 http://127.0.0.1:8504/api/pi-web/status 2>/dev/null) && [[ -n "$body" ]]; then
    api_ok="yes"
    api_ver=$(echo "$body" | python3 -c "import sys,json;d=json.load(sys.stdin);c=d.get('components',{});print('web v%s; sessiond %s' % (c.get('web',{}).get('runtimeVersion','?'), 'OK' if c.get('sessiond',{}).get('available') else 'unavailable'))" 2>/dev/null || echo "?")
    break
  fi
  sleep 0.5
done
if [[ -n "$api_ok" ]]; then
  printf "API health:         ${GRN}OK${NC} (%s)\n" "$api_ver"
else
  printf "API health:         ${RED}unreachable${NC}\n"
fi

echo ""
echo "=== last 10 log lines ==="
for log in "$LOG_FILE" "$SESSIOND_LOG_FILE"; do
  echo "--- $log ---"
  if [[ -f "$log" ]]; then
    tail -10 "$log"
  else
    echo "(no log file yet)"
  fi
done